# Copy to .env locally. Do not commit real secrets.
#
# This file lives at the repository root and is bind-mounted into the container
# at /workspace/.env. At startup bin/chat's Lisp process reads it and sets each
# KEY=value into its own process environment, so shell commands the agent runs
# through run_shell inherit them. Variables already present in the environment
# are not overridden. Values are never logged (only the names that were set).
#
# Line forms: KEY=value, optionally `export KEY=value`, with optional matching
# single/double quotes around the value. Blank lines and # comments are ignored.

# Required for live OpenRouter chat/tool sessions.
OPENROUTER_API_KEY=

# Optional. Exposed inside the container as GITHUB_TOKEN for git/gh and other
# tools the agent invokes via run_shell.
# GITHUB_TOKEN=
