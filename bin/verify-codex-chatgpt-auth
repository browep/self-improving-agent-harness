#!/usr/bin/env sh
# Opt-in, billable Codex ChatGPT subscription verification (issue #18).
#
# Prerequisite: a human has completed Codex-managed ChatGPT login so the local
# `codex` CLI/app-server holds a chatgpt session. This runs one minimal live
# turn charged against the ChatGPT/Codex subscription -- NOT OpenAI Platform
# API credits. It is deliberately NOT part of make test.
#
# Enable with: HARNESS_LIVE_CODEX_SMOKE=1 bin/verify-codex-chatgpt-auth
#
# Exit codes: 0 verified; 1 verification failed (redacted reason on stderr/
# stdout); 77 skipped (opt-in not set).
set -eu

if [ "${HARNESS_LIVE_CODEX_SMOKE:-}" != "1" ]; then
  printf '%s\n' 'SKIP: set HARNESS_LIVE_CODEX_SMOKE=1 to run the billable Codex verification.' >&2
  exit 77
fi

repo_root=$(CDPATH= cd -- "$(dirname -- "$0")/.." && pwd)

# Network is required (the app-server talks to Codex upstream); the workspace is
# writable so the sanitized evidence artifact can be written under agent-logs.
# Only non-secret control vars are forwarded; no OAuth token is passed in.
exec "$repo_root/bin/container" \
  --writable-workspace \
  --stdin-only \
  --env HARNESS_LIVE_CODEX_SMOKE \
  --env HARNESS_CODEX_EVIDENCE_DIR \
  --env HARNESS_LOG_DIR \
  --env CODEX_HOME \
  --load scripts/verify-codex-chatgpt-auth.lisp
