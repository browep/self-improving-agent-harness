#!/usr/bin/env sh
# One-off, explicit, billable protocol capture. Never invoked by make test.
set -eu
if [ "${HARNESS_CAPTURE_CLAUDE_SDK:-}" != "1" ]; then
  printf '%s\n' 'SKIP: set HARNESS_CAPTURE_CLAUDE_SDK=1 to authorize the disposable Claude subscription protocol capture.' >&2
  exit 77
fi
repo_root=$(CDPATH= cd -- "$(dirname -- "$0")/.." && pwd)
capture_dir="$repo_root/.capture/claude-sdk-contract"
compose_file="$repo_root/docker/claude-sdk-capture.compose.yml"
project="claude_sdk_capture_$$"
cleanup() {
  docker compose -p "$project" -f "$compose_file" down --volumes --remove-orphans >/dev/null 2>&1 || true
  rm -rf "$capture_dir"
}
trap cleanup EXIT INT TERM
[ -f "$repo_root/.env" ] || { printf '%s\n' 'capture requires the untracked repo-root .env with CLAUDE_CODE_OAUTH_TOKEN.' >&2; exit 2; }
mkdir -p "$capture_dir"
docker build --tag self-improving-agent-harness:dev "$repo_root" >/dev/null
docker compose -p "$project" -f "$compose_file" up -d proxy >/dev/null
for n in $(seq 1 30); do
  [ -s "$capture_dir/mitmproxy-ca-cert.pem" ] && break
  sleep 1
done
[ -s "$capture_dir/mitmproxy-ca-cert.pem" ] || { printf '%s\n' 'capture proxy CA was not created.' >&2; exit 1; }
# Trust only in the disposable client container; no host trust-store changes occur.
docker compose -p "$project" -f "$compose_file" run --rm client '
  set -eu
  cp /capture/mitmproxy-ca-cert.pem /usr/local/share/ca-certificates/claude-sdk-capture.crt
  update-ca-certificates >/dev/null
  claude -p "Return exactly CAPTURE_OK." --output-format json >/dev/null
'
[ -s "$capture_dir/claude-sdk-subscription-contract.v1.json" ] || { docker compose -p "$project" -f "$compose_file" logs --no-color proxy >&2; printf '%s\n' 'capture completed without a sanitized Anthropic Messages manifest.' >&2; exit 1; }
# Print only the sanitized manifest. The trap destroys all temporary capture material afterward.
cat "$capture_dir/claude-sdk-subscription-contract.v1.json"
